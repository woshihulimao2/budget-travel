# MiniMax API key（在 platform.minimaxi.com 申请）
MINIMAX_API_KEY="****"
# MiniMax 接口地址：国内账号用 https://api.minimaxi.com/v1，国际账号用 https://api.minimax.io/v1
# 注意：这里必须用 /v1（OpenAI兼容格式），不能用 /anthropic（Claude消息格式），代码走的是 openai SDK
MINIMAX_BASE_URL="https://api.minimaxi.com/v1"
# 使用的模型
MINIMAX_MODEL="MiniMax-M3"

# APP_URL: 本地开发可不填
APP_URL=""

# MySQL 连接信息（本地装的 MySQL 或阿里云 RDS 都填这里）
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD=""
DB_NAME="travel_guide"
