# MINIMAX_API_KEY: Required for MiniMax AI API calls (chat guide + itinerary customizer).
# Sign up at https://platform.minimaxi.com (mainland China) or https://www.minimax.io (international).
MINIMAX_API_KEY="MY_MINIMAX_API_KEY"
# MINIMAX_BASE_URL: use https://api.minimaxi.com/v1 for a mainland China account,
# or https://api.minimax.io/v1 for an international account.
MINIMAX_BASE_URL="https://api.minimaxi.com/v1"
# MINIMAX_MODEL: the chat model to use.
MINIMAX_MODEL="MiniMax-Text-01"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MySQL connection (local install or Alibaba Cloud RDS for MySQL)
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD=""
DB_NAME="travel_guide"

# ---------------------------------------------------------------------------
# Auth & security (added 2026-07)
# ---------------------------------------------------------------------------
# JWT_SECRET: signing key for access tokens. MUST be a high-entropy random
# string in production (e.g. `openssl rand -base64 48`). The server refuses
# to start in production if this is missing or set to the dev fallback.
JWT_SECRET="travel-guide-dev-secret-change-me"

# ---------------------------------------------------------------------------
# AI safety / rate-limit knobs (added 2026-07)
# ---------------------------------------------------------------------------
# Per-user sliding-window rate limit on /api/chat.
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=20
# Per-user rate limit on /api/customize (JSON output is more expensive).
CUSTOMIZE_RATE_LIMIT_WINDOW_MS=60000
CUSTOMIZE_RATE_LIMIT_MAX=5
# Max characters allowed per user message (server-side enforcement).
CHAT_INPUT_MAX_LEN=1000
# Max characters in a model reply before truncation.
CHAT_OUTPUT_MAX_LEN=4000
